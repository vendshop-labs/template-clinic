{
  "name": "vendshop-template-ecommerce",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "powershell -Command \"Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'node.exe' -and $_.CommandLine -match 'next' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue }; Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; next dev\"",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue\"",
    "seed": "npx tsx prisma/seed.ts",
    "seed:adriano": "npx tsx prisma/seed-adriano.ts",
    "seed:food-market": "npx tsx prisma/seed-food-market.ts",
    "seed:stepstyle": "npx tsx prisma/seed-stepstyle.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/stripe-js": "^9.8.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next": "^15.1.6",
    "next-intl": "^3.26.3",
    "openai": "^6.44.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "stripe": "^22.2.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "prisma": "^7.8.0",
    "replicate": "^1.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
